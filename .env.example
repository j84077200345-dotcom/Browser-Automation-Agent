# 複製成 .env 後填入內容。真正的 .env 絕對不要提交進版控。

# LLM 供應商:anthropic 或 openai。agent 迴圈與供應商無關,可自由切換。
LLM_PROVIDER=anthropic

# 依所選供應商填入對應的 API key(只需填入使用的那一個)。
# agent 在執行期用此 key 來規劃瀏覽器動作。
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# agent 迴圈使用的模型。留空則自動採用該供應商的預設值:
#   anthropic → claude-sonnet-4-6
#   openai    → gpt-4o
AGENT_MODEL=

# 每次 run 的最大推理/動作步數(agent 迴圈的安全上限)。
AGENT_MAX_STEPS=25

# 是否以 headless 模式執行瀏覽器(伺服器/容器上設為 true,想在本機觀看則設為 false)。
HEADLESS=true

# Web 伺服器埠號(Zeabur 會自動注入 $PORT,此為本機預設值)。
PORT=8000

# 選填:限制公開 URL 上每日可觸發的 agent run 次數,用以保護 API 額度。0 = 不限制。
DAILY_RUN_LIMIT=50
