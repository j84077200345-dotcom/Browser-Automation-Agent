# 複製成 .env 後填入內容。真正的 .env 絕對不要提交進版控。

# 必填:agent 在執行期用來規劃瀏覽器動作的 Anthropic API key。
ANTHROPIC_API_KEY=sk-ant-...

# agent 迴圈所使用的 Claude 模型。Sonnet 在推理能力與成本之間取得良好平衡。
AGENT_MODEL=claude-sonnet-4-6

# 每次 run 的最大推理/動作步數(agent 迴圈的安全上限)。
AGENT_MAX_STEPS=25

# 是否以 headless 模式執行瀏覽器(伺服器/容器上設為 true,想在本機觀看則設為 false)。
HEADLESS=true

# Web 伺服器埠號(Zeabur 會自動注入 $PORT,此為本機預設值)。
PORT=8000

# 選填:限制公開 URL 上每日可觸發的 agent run 次數,用以保護 API 額度。0 = 不限制。
DAILY_RUN_LIMIT=50
